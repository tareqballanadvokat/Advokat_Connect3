# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.
# This file (.env.example) IS committed — it documents what variables are needed.
#
# IMPORTANT: The build runs locally (npm run build). Azure does NOT build the app.
# These values are baked into the bundle at build time by webpack DefinePlugin.
# Setting them in Azure App Settings has NO effect.

# Azure tenant ID (used by Azure CLI tooling only, not at runtime)
AZURE_TENANT_ID=

# DevExtreme UI license key (obtain from https://js.devexpress.com/licensing/)
DEVEXTREME_LICENSE_KEY=

# WebSocket URI of the SIP signaling server
# host, port, and sipUri are derived from this automatically
SIP_WS_URI=wss://your-signaling-server.com:443
# For local development:
# SIP_WS_URI=wss://localhost:8009
