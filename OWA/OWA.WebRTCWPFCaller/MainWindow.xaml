<Window x:Class="OWA.WebRTCWPFCaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OWA.WebRTCWPFCaller"
        mc:Ignorable="d"
        Title="Caller" Height="700" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <Label  HorizontalAlignment="Center">Caller</Label>
            <StackPanel Margin="10" Height="30" Orientation="Horizontal">
                <Label Width="150" VerticalAlignment="Center">Signaling server (IP:PORT)</Label>
                <TextBox TextWrapping="NoWrap" TextAlignment="Left" Name="SignalingServer" 
                     AcceptsReturn="False" Text="ws://92.205.233.81:8081" 
                     Height="20" Width="200"/>
                <Button  Name="SignalingServerConnectBtn" Content="🔗Connect" Click="SignalingServerConnectBtn_Click" Margin="5"/>
                <Ellipse Name="StatusIndicator" Width="10" Height="10" Fill="Red" Margin="5"/>
                <Label Name="ConnectionStatus" Content="Disconnected"/>
            </StackPanel>

            <Button Name="AutoConnectBtn" Content="🔗 Połącz z serwerem - AUTO" Click="AutoConnectBtn_Click" Margin="5"/>
          


            <Button Name="ConnectBtn" Content="🔗 Połącz z serwerem" Click="ConnectBtn_Click" Margin="5"/>
            <Button Name="OfferBtn" Content="📡 Stwórz ofertę" Click="OfferBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="WaitAnswerBtn" Content="⏳ Oczekuj na odpowiedź" Click="WaitAnswerBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="SendICEBtn" Content="❄️ Wyślij ICE" Click="SendICEBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="DisconnectBtn" Content="❌ Rozłącz" Click="DisconnectBtn_Click" Margin="5" IsEnabled="False"/>
            <TextBox Name="LogBox" Height="300" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>

            <!-- Pole do wpisywania wiadomości -->
            <TextBox Name="MessageBox" Margin="5" Height="30"  />
            <Button Name="SendMessageBtn" Content="📨 Wyślij wiadomość" Click="SendMessageBtn_Click" Margin="5" IsEnabled="True"/>

        </StackPanel>
    </Grid>
</Window>
