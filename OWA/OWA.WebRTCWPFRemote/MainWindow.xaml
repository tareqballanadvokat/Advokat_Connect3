<Window x:Class="OWA.WebRTCWPFRemote.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d"
        Closed="Window_Closed"
        Title="Remote" Height="718" Width="800">
    <Grid>
        <StackPanel Margin="20,-18,0,38">
            <Label  HorizontalAlignment="Center">Remote</Label>
            <StackPanel Margin="10" Background="Cyan">
                <Label  HorizontalAlignment="Center">Signaling server configuration</Label>
                <StackPanel  Height="30" Orientation="Horizontal">
                    <Label Width="150" VerticalAlignment="Center">Signaling server (IP:PORT)</Label>
                    <TextBox TextWrapping="NoWrap" TextAlignment="Left" Name="SipSignalingServer" 
                      AcceptsReturn="False" Text="92.205.233.81:8081" 
                      Height="20" Width="116"/>

                    <Label Width="65" VerticalAlignment="Center">My name:</Label>
                    <TextBox TextWrapping="NoWrap" TextAlignment="Left" Name="RegistrationName" AcceptsReturn="False" Text="server" TextChanged="RegistrationName_TextChanged" Height="20" Width="50"/>
                    <Label Width="107">Destination name:</Label>
                    <TextBox TextWrapping="NoWrap" TextAlignment="Left" x:Name="DestinationName" AcceptsReturn="False" Text="caller" TextChanged="DestinationName_TextChanged" Height="20" Width="72"/>

                </StackPanel>

                <StackPanel Height="30" Orientation="Horizontal">

                    <Label Width="243" ToolTip="My Local IP:PORT (ex. 192.168.0.1:1234) based on initial calculated DNS IP">My Local IP:PORT (ex. 192.168.0.1:7654):</Label>
                    <ComboBox Name="SipSignalingServerComboBox" Width="100" Height="20" Margin="5" />

                    <TextBox TextWrapping="NoWrap" TextAlignment="Left" x:Name="DnsIPAndPort" AcceptsReturn="False" Text="7080" Height="20" Width="55"/>

                    <Button  Name="SignalingServerRegistrationBtn" Content="🔗Register" Click="SignalingServerRegistrationBtn_Click" Margin="5"/>
                    <Ellipse x:Name="StatusIndicator" Width="10" Height="10" Fill="Red"/>
                    <Label x:Name="ConnectionStatus" Content="Disconnected"/>
         
                </StackPanel>
            </StackPanel> 
        

            <StackPanel Margin="10" Background="Fuchsia" Height="170">
                <Label  HorizontalAlignment="Center">P2P configuration/status</Label>

                <StackPanel Margin="10" Background="Fuchsia"  Orientation="Horizontal" >

                    <Label Width="225" ToolTip="My Local IP:PORT (ex. 192.168.0.1:7654) based on initial calculated DNS IP">My Local IP:PORT (ex. 192.168.0.1:7654):</Label>
                    <ComboBox Name="P2PServerComboBox" Width="100" Height="20" Margin="5" />

                    <TextBox TextWrapping="NoWrap" TextAlignment="Left" x:Name="P2PPort" TextChanged="P2PPort_TextChanged" AcceptsReturn="False" Text="9090" Height="20" Width="55"/>
                    <Ellipse x:Name="P2PStatusIndicator" Width="10" Height="10" Fill="Red"/>
                    <Label x:Name="P2PConnectionStatus" Content="Disconnected"/>

                     <TextBox TextWrapping="NoWrap" TextAlignment="Left" x:Name="DelayMilisecondsTextBox" TextChanged="DelayMilisecondsTextBox_TextChanged"  AcceptsReturn="False" Text="2000" Height="20" Width="55"/>
           
                </StackPanel>
                <StackPanel   Background="Fuchsia"  Orientation="Horizontal" >
                    <ComboBox Name="P2PServersComboBox" Width="240" Height="20" Margin="5" />
                    <Label Width="61">STUN Url:</Label>
                    <TextBox Name="P2PStunTextBox" TextWrapping="Wrap" Text="" Width="169" Height="22"/>
                    <Button Name="P2PAddStunBtn" Content="Add" Click="P2PAddStunBtn_Click" Margin="5"/>

                </StackPanel>
                <StackPanel   Background="Fuchsia"  Orientation="Horizontal" >
                    <Button Name="P2PRemoveStunBtn" Content="Remove selected" Click="P2PRemoveStunBtn_Click" Margin="5" Width="240"/>

                    <Label>TURN Url:</Label>
                    <TextBox Name="P2PTurnUrlTextBox" TextWrapping="Wrap" Text="" Width="166" Height="22"/>
                    <Label>login</Label>
                    <TextBox Name="P2PTurnLoginTextBox"  TextWrapping="Wrap" Text="" Width="54" Height="22"/>
                    <Label>password</Label>
                    <TextBox Name="P2PTurnPasswdTextBox" TextWrapping="Wrap" Text="" Width="59" Height="22"/>
                    <Button  Name="P2PAddTurnBtn" Content="Add" Click="P2PAddTurnBtn_Click" Margin="5"/>
                </StackPanel>
                <StackPanel   Background="Fuchsia"  Orientation="Vertical" >
                    <Button Name="P2PDisconnectBtn" Content="Disctonnect everything" Click="P2PDisconnectBtn_Click" Margin="5"/>
                </StackPanel>
            </StackPanel>






            <!-- Pole do wpisywania wiadomości -->
            <TextBox Name="MessageBox" Margin="5" Height="30"  />
            <Button Name="SendMessageBtn" Content="📨 Send message P2P" Click="SendMessageBtn_Click" Margin="5" IsEnabled="True"/>
            <Button Name="SendMessageViaSignalingServerBtn" Content="📨 Send message via Signaling server" Click="SendMessageViaSignalingServerBtn_Click" Margin="5" IsEnabled="True"/>


            <TextBox Name="LogBox" Height="170" IsReadOnly="True"  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
            <Button Name="AutoConnectBtn" Content="🔗 Connect with NODE.JS signaling server - AUTO" Click="AutoConnectBtn_Click" Margin="5"/>


            <StackPanel Margin="10" Height="30" Orientation="Horizontal" Visibility="Hidden">
                <Label Width="150" VerticalAlignment="Center">Signaling server (IP:PORT)</Label>
                <TextBox TextWrapping="NoWrap" TextAlignment="Left" Name="SignalingServer" 
                     AcceptsReturn="False" Text="ws://92.205.233.81:8081" 
                     Height="20" Width="200"/>

            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
