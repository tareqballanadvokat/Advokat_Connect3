<Window x:Class="OWA.WebRTCWPFRemote.MainWindow" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        mc:Ignorable="d"
        Title="Remote" Height="700" Width="800">
    <Grid>
        <StackPanel Margin="10">
            <Button Name="ConnectBtn" Content="🔗 Połącz z serwerem" Click="ConnectBtn_Click" Margin="5"/>
            <Button Name="WaitOfferBtn" Content="⏳ Oczekuj na Offer" Click="WaitOfferBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="GenerateAnswerBtn" Content="📡 Wygeneruj Answer" Click="GenerateAnswerBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="SendICEBtn" Content="❄️ Wyślij ICE" Click="SendICEBtn_Click" Margin="5" IsEnabled="False"/>
            <Button Name="DisconnectBtn" Content="❌ Rozłącz" Click="DisconnectBtn_Click" Margin="5" IsEnabled="False"/>
            <TextBox Name="LogBox" Height="300" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
            <!-- Pole do wpisywania wiadomości -->
            <TextBox Name="MessageBox" Margin="5" Height="30"  />
            <Button Name="SendMessageBtn" Content="📨 Wyślij wiadomość" Click="SendMessageBtn_Click" Margin="5" IsEnabled="True"/>
   
        </StackPanel>
    </Grid>
</Window>
